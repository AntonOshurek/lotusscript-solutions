import type { Field } from './field';

interface ChangedFieldPayload<
  T extends Record<string, unknown>,
> {
  name: keyof T;
  oldValue: unknown;
  newValue: unknown;
  isClear: boolean;
}

interface ChangeConfirmHtmlField {
  label: string;
  oldValue: unknown;
  newValue: unknown;
  isClear: boolean;
}

interface CreateChangeConfirmHtmlPayload {
  message: string;
  recordLabel: string;
  recordId: string;
  fields: ChangeConfirmHtmlField[];
}

const getChangedFields = <
  T extends Record<string, unknown>,
>(
  original: T,
  updated: T,
  fields: Partial<Record<keyof T, Field>>,
): ChangedFieldPayload<T>[] => {
  return (Object.keys(fields) as Array<keyof T>)
    .filter(field => fields[field]?.editable)
    .filter(field => original[field] !== updated[field])
    .map(field => {
      const oldValue = original[field];
      const newValue = updated[field];

      return {
        name: field,
        oldValue,
        newValue,
        isClear: isEmptyValue(newValue),
      };
    });
};

const isEmptyValue = (value: unknown): boolean => {
  return (
    value === null ||
    value === undefined ||
    value === ''
  );
};

const createChangeConfirmHtml = (
  payload: CreateChangeConfirmHtmlPayload,
): string => {
  const fieldsHtml = payload.fields
    .map(field => {
      const oldValue =
        formatChangeConfirmValue(field.oldValue);

      const newValue = field.isClear
        ? 'Wartość zostanie usunięta'
        : formatChangeConfirmValue(field.newValue);

      return `
        <li>
          <b>${field.label}</b><br/>
          Stara wartość: <b>${oldValue}</b><br/>
          Nowa wartość: <b>${newValue}</b>
        </li>
      `;
    })
    .join('');

  return `
    <p>${payload.message}</p>
    <p><b>${payload.recordLabel}:</b> ${payload.recordId}</p>
    <ul>${fieldsHtml}</ul>
  `;
};

const formatChangeConfirmValue = (
  value: unknown,
): string => {
  if (isEmptyValue(value)) {
    return 'Brak wartości';
  }

  return String(value);
};

export {
  createChangeConfirmHtml,
  getChangedFields,
  isEmptyValue,
};

export type {
  ChangedFieldPayload,
  ChangeConfirmHtmlField,
  CreateChangeConfirmHtmlPayload,
};




