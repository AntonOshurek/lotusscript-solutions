export interface ChangeConfirmHtmlField {
  label: string;
  oldValue: unknown;
  newValue: unknown;
  isClear: boolean;
}

export interface CreateChangeConfirmHtmlPayload {
  message: string;
  recordLabel: string;
  recordId: string;
  fields: ChangeConfirmHtmlField[];
}

export function createChangeConfirmHtml(
  payload: CreateChangeConfirmHtmlPayload,
): string {
  const fieldsHtml = payload.fields
    .map((field) => {
      const oldValue = formatChangeConfirmValue(field.oldValue);
      const newValue = field.isClear
        ? 'Wartość zostanie usunięta'
        : formatChangeConfirmValue(field.newValue);

      return `
        <li>
          <b>${field.label}</b><br/>
          Stara wartość: <b>${oldValue}</b><br/>
          Nowa wartość: <b>${newValue}</b>
        </li>
      `;
    })
    .join('');

  return `
    <p>${payload.message}</p>
    <p><b>${payload.recordLabel}:</b> ${payload.recordId}</p>
    <ul>${fieldsHtml}</ul>
  `;
}

function formatChangeConfirmValue(value: unknown): string {
  if (value === null || value === undefined || value === '') {
    return 'Brak wartości';
  }

  return String(value);
}
