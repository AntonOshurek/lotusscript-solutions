import { inject, Injectable } from '@angular/core';

import {
  UpdateTransactionPcFeature,
  type UpdateTransactionPcField,
} from '@features/transaction-pc/update-transaction-pc';

import {
  TRANSACTION_FIELDS,
  type TransactionPc,
  type TransactionPcFieldName,
} from '@entities/transaction-pc';

@Injectable()
export class UpdateTransactionPcFacade {
  private readonly updateTransactionPcFeature = inject(
    UpdateTransactionPcFeature,
  );

  public updateRow(payload: {
    original: TransactionPc;
    updated: TransactionPc;
  }): void {
    const fields = this.getChangedFields(payload.original, payload.updated);

    if (fields.length === 0) {
      return;
    }

    this.updateTransactionPcFeature.update({
      row: payload.updated,
      fields,
      makerReason: 'Transaction PC edit',
    }).subscribe({
      next: () => {
        // success toast / refresh
      },
      error: () => {
        // error toast / rollback
      },
    });
  }

  private getChangedFields(
    original: TransactionPc,
    updated: TransactionPc,
  ): UpdateTransactionPcField[] {
    return Object.keys(TRANSACTION_FIELDS)
      .map((field) => field as TransactionPcFieldName)
      .filter((field) => TRANSACTION_FIELDS[field].editable)
      .filter((field) => original[field] !== updated[field])
      .map((field) => {
        const value = updated[field];

        return {
          field,
          value,
          op: this.isEmptyValue(value) ? 'CLEAR' : 'SET',
        };
      });
  }

  private isEmptyValue(value: unknown): boolean {
    return value === null || value === undefined || value === '';
  }
}
