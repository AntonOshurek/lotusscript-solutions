import { inject, Injectable } from '@angular/core';
import type { Observable } from 'rxjs';

// ERROR
import { mapErrorToUiError } from '@shared/error';
// FIELD
import type { Field } from '@shared/field';
// MODAL
import { MtModalService } from '@citi-icg-172888/ng-icgds/modal';
// ROW EDIT
import type {
  RowEditField,
  RowEditValue,
} from '@shared/row-edit';

interface EditableRowChangePayload<
  T extends Record<string, unknown>,
> {
  original: T;
  updated: T;
  onSuccess?: () => void;
  onError?: () => void;
  onCancel?: () => void;
}

interface EditableRowChangeConfig<
  T extends Record<string, unknown>,
  TResponse,
> {
  fieldNames: Partial<Record<keyof T, Field>>;
  getRecordId: (row: T) => string;

  confirmTitle: string;
  confirmMessage: string;
  recordLabel: string;

  successTitle: string;
  successHtml: string;

  errorTitle: string;
  errorMessage: string;

  submit: (
    updated: T,
    newValues: RowEditField<Extract<keyof T, string>>,
  ) => Observable<TResponse>;
}

@Injectable({
  providedIn: 'root',
})
export class EditableRowChangeService {
  private readonly modalService = inject(MtModalService);

  public handle<
    T extends Record<string, unknown>,
    TResponse,
  >(
    payload: EditableRowChangePayload<T>,
    config: EditableRowChangeConfig<T, TResponse>,
  ): void {
    const changedFields = this.getChangedFields(
      payload.original,
      payload.updated,
      config.fieldNames,
    );

    if (changedFields.length === 0) {
      return;
    }

    this.modalService.open({
      status: 'warning',
      title: config.confirmTitle,
      html: this.createConfirmHtml({
        message: config.confirmMessage,
        recordLabel: config.recordLabel,
        recordId: config.getRecordId(payload.updated),
        fields: changedFields.map(field => ({
          label:
            config.fieldNames[field.name]?.label ??
            String(field.name),
          oldValue: field.oldValue,
          newValue: field.newValue,
        })),
      }),
      type: 'confirm',
      afterUserAction: event => {
        if (event.action === 'accept') {
          const newValues = this.createNewValues(changedFields);

          this.submit(
            payload,
            config,
            newValues,
          );

          return;
        }

        payload.onCancel?.();
      },
    });
  }

  private submit<
    T extends Record<string, unknown>,
    TResponse,
  >(
    payload: EditableRowChangePayload<T>,
    config: EditableRowChangeConfig<T, TResponse>,
    newValues: RowEditField<Extract<keyof T, string>>,
  ): void {
    config.submit(payload.updated, newValues).subscribe({
      next: () => {
        this.modalService.open({
          status: 'success',
          title: config.successTitle,
          html: config.successHtml,
          type: 'alert',
        });

        payload.onSuccess?.();
      },
      error: (error: unknown) => {
        const uiError = mapErrorToUiError(
          error,
          config.errorMessage,
        );

        this.modalService.open({
          status: 'danger',
          title: config.errorTitle,
          html: `
            <p>${uiError.title}</p>
            <p>${uiError.message}</p>
          `,
          type: 'alert',
        });

        payload.onError?.();
      },
    });
  }

  private getChangedFields<
    T extends Record<string, unknown>,
  >(
    original: T,
    updated: T,
    fields: Partial<Record<keyof T, Field>>,
  ): Array<{
    name: Extract<keyof T, string>;
    oldValue: RowEditValue;
    newValue: RowEditValue;
  }> {
    return (
      Object.keys(fields) as Array<Extract<keyof T, string>>
    )
      .filter(fieldName => fields[fieldName]?.editable)
      .filter(
        fieldName =>
          original[fieldName] !== updated[fieldName],
      )
      .map(fieldName => ({
        name: fieldName,
        oldValue: original[fieldName] as RowEditValue,
        newValue: updated[fieldName] as RowEditValue,
      }));
  }

  private createNewValues<
    TFieldName extends string,
  >(
    changedFields: Array<{
      name: TFieldName;
      newValue: RowEditValue;
    }>,
  ): RowEditField<TFieldName> {
    return changedFields.reduce<RowEditField<TFieldName>>(
      (newValues, field) => {
        newValues[field.name] = field.newValue;

        return newValues;
      },
      {},
    );
  }

  private createConfirmHtml(
    payload: {
      message: string;
      recordLabel: string;
      recordId: string;
      fields: Array<{
        label: string;
        oldValue: RowEditValue;
        newValue: RowEditValue;
      }>;
    },
  ): string {
    const fieldsHtml = payload.fields
      .map(field => {
        const oldValue = this.formatValue(field.oldValue);

        const newValue =
          field.newValue === null
            ? 'Wartość zostanie usunięta'
            : this.formatValue(field.newValue);

        return `
          <li>
            <b>${field.label}</b><br/>
            Stara wartość: <b>${oldValue}</b><br/>
            Nowa wartość: <b>${newValue}</b>
          </li>
        `;
      })
      .join('');

    return `
      <p>${payload.message}</p>
      <p>
        <b>${payload.recordLabel}:</b>
        ${payload.recordId}
      </p>
      <ul>${fieldsHtml}</ul>
    `;
  }

  private formatValue(value: RowEditValue): string {
    return value === null
      ? 'Brak wartości'
      : String(value);
  }
}

export type {
  EditableRowChangeConfig,
  EditableRowChangePayload,
};
