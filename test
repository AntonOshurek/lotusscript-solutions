import { MtNavigationMenuItem } from '@citi-icg-172888/ng-icgds/navigation-menu';
import { MtMenuItem } from '@citi-icg-172888/ng-icgds/menu';
import { AuthzService } from '@entities/authz';
import { NavItemData } from './nav.types';

export function filterNavItemsByPermissions(
  items: MtNavigationMenuItem[],
  authz: AuthzService,
): MtNavigationMenuItem[] {
  return items
    .map(item => filterNavigationItem(item, authz))
    .filter((item): item is MtNavigationMenuItem => item !== null);
}

function filterNavigationItem(
  item: MtNavigationMenuItem,
  authz: AuthzService,
): MtNavigationMenuItem | null {
  const data = item.data as NavItemData | undefined;

  if (data?.permission && !authz.can(data.permission.resourceCode, data.permission.actionCode)) {
    return null;
  }

  const filteredItems = item.items
    ?.map(child => filterMenuItem(child as MtMenuItem, authz))
    .filter((child): child is MtMenuItem => child !== null);

  if (item.items && filteredItems?.length === 0) {
    return null;
  }

  return {
    ...item,
    ...(filteredItems ? { items: filteredItems } : {}),
  };
}

function filterMenuItem(
  item: MtMenuItem,
  authz: AuthzService,
): MtMenuItem | null {
  const data = item.data as NavItemData | undefined;

  if (data?.permission && !authz.can(data.permission.resourceCode, data.permission.actionCode)) {
    return null;
  }

  const filteredItems = item.items
    ?.map(child => filterMenuItem(child, authz))
    .filter((child): child is MtMenuItem => child !== null);

  if (item.items && filteredItems?.length === 0) {
    return null;
  }

  return {
    ...item,
    ...(filteredItems ? { items: filteredItems } : {}),
  };
}
