private createConfirmHtml(

  payload: UpdateRowPayload,

  fields: UpdateTransactionPcPayloadField[],

): string {

  const changedFieldsHtml = fields

    .map((field) => {

      const label = TRANSACTION_FIELDS[field.field].label;

      const oldValue = this.formatValue(payload.original[field.field]);

      const newValue = field.op === 'CLEAR'

        ? 'Wartość zostanie usunięta'

        : this.formatValue(field.value);

      return `

        <li>

          <b>${label}</b><br/>

          Stara wartość: <b>${oldValue}</b><br/>

          Nowa wartość: <b>${newValue}</b>

        </li>

      `;

    })

    .join('');

  return `

    <p>Czy na pewno chcesz zmienić wartości rekordu transakcji PC?</p>

    <p><b>ID transakcji:</b> ${payload.updated.transaction_id}</p>

    <ul>${changedFieldsHtml}</ul>

  `;

}
