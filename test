// gcm-change.model.ts

import { z } from 'zod';

type GcmTargetCode =
  | 'AMLDB_PC'
  | 'AMLDB_ACC'
  | 'AMLDB_CUST_GOLDEN'
  | 'AMLDB_PS_GOLDEN';

type GcmRowEditValue = string | number | null;

type GcmRowEditNewValues = Record<string, GcmRowEditValue>;

interface GcmRowEditRow {
  pkValue: string;
  expectedVersion: number;
  newValues: GcmRowEditNewValues;
}

interface GcmRowEditProposeRequest {
  targetCode: GcmTargetCode;
  rows: GcmRowEditRow[];
  clientKey: string;
  onBehalfOf?: string;
}

interface GcmRowEditProposeResponse {
  data: {
    requestId: string;
    workflowInstanceId?: string[];
  };
}

interface GcmUpdateFeaturePayload<
  TField extends string,
> {
  targetCode: GcmTargetCode;
  pkValue: string;
  expectedVersion: number;
  newValues: Partial<
    Record<TField, GcmRowEditValue>
  >;
  clientKey: string;
  onBehalfOf?: string;
}

const gcmTargetCodeSchema = z.enum([
  'AMLDB_PC',
  'AMLDB_ACC',
  'AMLDB_CUST_GOLDEN',
  'AMLDB_PS_GOLDEN',
]);

const gcmRowEditValueSchema = z.union([
  z.string(),
  z.number(),
  z.null(),
]);

const gcmRowEditNewValuesSchema = z.record(
  z.string(),
  gcmRowEditValueSchema,
);

const gcmRowEditRowSchema = z.object({
  pkValue: z.string().min(1).max(512),
  expectedVersion: z.number().int(),
  newValues: gcmRowEditNewValuesSchema,
});

const gcmRowEditProposeRequestSchema = z.object({
  targetCode: gcmTargetCodeSchema,
  rows: z
    .array(gcmRowEditRowSchema)
    .min(1)
    .max(25),
  clientKey: z.string().min(1).max(128),
  onBehalfOf: z.string().optional(),
});

const gcmRowEditProposeResponseSchema = z.object({
  data: z.object({
    requestId: z.string(),
    workflowInstanceId: z
      .array(z.string())
      .optional(),
  }),
});

export type {
  GcmTargetCode,
  GcmRowEditValue,
  GcmRowEditNewValues,
  GcmRowEditRow,
  GcmRowEditProposeRequest,
  GcmRowEditProposeResponse,
  GcmUpdateFeaturePayload,
};

export {
  gcmRowEditProposeRequestSchema,
  gcmRowEditProposeResponseSchema,
};
