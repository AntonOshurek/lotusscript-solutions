// pages/admin/users-permissions/model/users-permissions.mapper.ts

export function mapUsersPermissionsToTreeRows(
  users: UserPermissionDto[],
): UserPermissionTreeRow[] {
  return users.flatMap((user) => {
    const userRow: UserPermissionTreeRow = {
      id: `user-${user.id}`,
      type: 'user',
      path: [`${user.code}`],
      code: user.code,
      name: user.name,
      status: user.status,
    };

    const groupRows = user.groups.flatMap((group) => {
      const groupRow: UserPermissionTreeRow = {
        id: `user-${user.id}-group-${group.id}`,
        type: 'group',
        path: [`${user.code}`, `${group.code}`],
        code: group.code,
        description: group.description,
        status: group.status,
      };

      const roleRows: UserPermissionTreeRow[] = group.roles.map((role) => ({
        id: `user-${user.id}-group-${group.id}-role-${role.id}`,
        type: 'role',
        path: [`${user.code}`, `${group.code}`, `${role.code}`],
        code: role.code,
        description: role.description,
        status: role.status,
      }));

      return [groupRow, ...roleRows];
    });

    return [userRow, ...groupRows];
  });
}
