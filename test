Option Public
Option Declare

Sub Initialize

    Dim session As New NotesSession
    Dim database As NotesDatabase
    Dim pendingView As NotesView
    Dim pendingCollection As NotesDocumentCollection
    
    Dim newVersionDoc As NotesDocument
    Dim nextNewVersionDoc As NotesDocument
    
    Dim previousVersionUNID As String
    Dim previousVersionDoc As NotesDocument
    Dim previousVersionsCollection As NotesDocumentCollection
    
    Dim previousVersionDocItem As NotesDocument
    
    Dim canProcess As Boolean
    Dim errorText As String

    Set database = session.CurrentDatabase
    Set pendingView = database.GetView("vwReparentPending")
    
    If pendingView Is Nothing Then Exit Sub
    
    Set pendingCollection = pendingView.GetAllDocumentsByKey("PENDING", True)
    If pendingCollection Is Nothing Then Exit Sub

    Set newVersionDoc = pendingCollection.GetFirstDocument()

    Do While Not newVersionDoc Is Nothing

        Set nextNewVersionDoc = pendingCollection.GetNextDocument(newVersionDoc)

        canProcess = True
        errorText = ""

        ' 🔍 Проверка new версии
        On Error Resume Next
        If Not newVersionDoc.Save(False, False) Or Err <> 0 Then
            errorText = "Cannot save new version: " & newVersionDoc.UniversalID & _
                        " | Error " & CStr(Err) & ": " & Error$
            canProcess = False
        End If
        Err = 0
        On Error GoTo 0

        ' 🔍 Получаем предыдущую версию
        If canProcess Then
            If newVersionDoc.HasItem("PrevVersionUNID") Then
                previousVersionUNID = newVersionDoc.GetItemValue("PrevVersionUNID")(0)
            Else
                previousVersionUNID = ""
            End If

            If previousVersionUNID = "" Then
                errorText = "PrevVersionUNID is empty"
                canProcess = False
            End If
        End If

        ' 🔍 Загружаем предыдущий документ
        If canProcess Then
            Set previousVersionDoc = database.GetDocumentByUNID(previousVersionUNID)

            If previousVersionDoc Is Nothing Then
                errorText = "Previous version not found: " & previousVersionUNID
                canProcess = False
            End If
        End If

        ' 🔍 Получаем все старые версии
        If canProcess Then
            Set previousVersionsCollection = previousVersionDoc.Responses

            If previousVersionsCollection Is Nothing Then
                errorText = "No responses found for: " & previousVersionDoc.UniversalID
                canProcess = False
            End If
        End If

        ' 🔍 Проверка всех старых документов
        If canProcess Then
            Set previousVersionDocItem = previousVersionsCollection.GetFirstDocument()

            Do While Not previousVersionDocItem Is Nothing

                On Error Resume Next
                If Not previousVersionDocItem.Save(False, False) Or Err <> 0 Then
                    errorText = "Cannot save old version: " & previousVersionDocItem.UniversalID & _
                                " | Error " & CStr(Err) & ": " & Error$
                    canProcess = False
                    Err = 0
                    On Error GoTo 0
                    Exit Do
                End If
                Err = 0
                On Error GoTo 0

                Set previousVersionDocItem = previousVersionsCollection.GetNextDocument(previousVersionDocItem)
            Loop
        End If

        ' 🚀 Перепривязка
        If canProcess Then
            Set previousVersionDocItem = previousVersionsCollection.GetFirstDocument()

            Do While Not previousVersionDocItem Is Nothing

                If previousVersionDocItem.UniversalID <> newVersionDoc.UniversalID Then

                    On Error Resume Next
                    Call previousVersionDocItem.MakeResponse(newVersionDoc)

                    If Err <> 0 Then
                        errorText = "MakeResponse failed: " & previousVersionDocItem.UniversalID & _
                                    " | Error " & CStr(Err) & ": " & Error$
                        canProcess = False
                        Err = 0
                        On Error GoTo 0
                        Exit Do
                    End If

                    If Not previousVersionDocItem.Save(False, False) Or Err <> 0 Then
                        errorText = "Save after MakeResponse failed: " & previousVersionDocItem.UniversalID & _
                                    " | Error " & CStr(Err) & ": " & Error$
                        canProcess = False
                        Err = 0
                        On Error GoTo 0
                        Exit Do
                    End If

                    Err = 0
                    On Error GoTo 0
                End If

                Set previousVersionDocItem = previousVersionsCollection.GetNextDocument(previousVersionDocItem)
            Loop
        End If

        ' 🧾 Запись результата
        On Error Resume Next

        If canProcess Then
            Call newVersionDoc.ReplaceItemValue("ReparentStatus", "DONE")
            Call newVersionDoc.ReplaceItemValue("ReparentError", "")
        Else
            Call newVersionDoc.ReplaceItemValue("ReparentStatus", "ERROR")
            Call newVersionDoc.ReplaceItemValue("ReparentError", errorText)
        End If

        Call newVersionDoc.ReplaceItemValue("ReparentProcessedAt", Now)
        Call newVersionDoc.Save(False, False)

        Err = 0
        On Error GoTo 0

        Set newVersionDoc = nextNewVersionDoc
    Loop

End Sub
