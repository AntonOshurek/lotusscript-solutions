import { inject, Injectable } from '@angular/core';

// ENTITIES
import {
  TRANSACTION_PC_FIELDS,
  type TransactionPc,
  type TransactionPcFieldName,
} from '@entities/transaction-pc';

// FEATURES
import {
  UpdateTransactionPcFeature,
  type UpdateTransactionPcNewValues,
} from '@features/transaction-pc';

// ROW EDIT
import type { RowEditValue } from '@shared/row-edit';

// TABLE
import {
  EditableRowChangeService,
  type ChangedFieldPayload,
  type EditableRowChangePayload,
} from '@shared/table';

@Injectable()
export class UpdateTransactionPcFacade {
  private readonly editableRowChangeService =
    inject(EditableRowChangeService);

  private readonly updateTransactionPcFeature =
    inject(UpdateTransactionPcFeature);

  public updateRow(
    payload: EditableRowChangePayload<TransactionPc>,
  ): void {
    this.editableRowChangeService.handle(payload, {
      fieldsConfig: TRANSACTION_PC_FIELDS,

      getRecordId: row =>
        String(row.transaction_id),

      confirmTitle:
        'Potwierdź zmianę transakcji PC',

      confirmMessage:
        'Czy na pewno chcesz zmienić wartości rekordu transakcji PC?',

      recordLabel:
        'ID transakcji PC',

      successTitle:
        'Zapisano zmianę',

      successHtml:
        '<p>Zmiany rekordu transakcji PC zostały zapisane.</p>',

      errorTitle:
        'Nieudana próba zmiany rekordu',

      errorMessage:
        'Nie udało się zapisać rekordu transakcji PC',

      submit: (updated, changedFields) =>
        this.updateTransactionPcFeature.update({
          pkValue: String(updated.transaction_id),
          newValues:
            this.createNewValues(changedFields),
        }),
    });
  }

  private createNewValues(
    changedFields:
      ChangedFieldPayload<TransactionPc>[],
  ): UpdateTransactionPcNewValues {
    return changedFields.reduce<
      UpdateTransactionPcNewValues
    >((newValues, field) => {
      const fieldName =
        field.name as TransactionPcFieldName;

      newValues[fieldName] =
        this.toRowEditValue(
          field.newValue,
          field.isClear,
        );

      return newValues;
    }, {});
  }

  private toRowEditValue(
    value: unknown,
    isClear: boolean,
  ): RowEditValue {
    if (isClear) {
      return null;
    }

    if (
      typeof value === 'string' ||
      typeof value === 'number'
    ) {
      return value;
    }

    throw new Error(
      `Unsupported row edit value: ${String(value)}`,
    );
  }
}
