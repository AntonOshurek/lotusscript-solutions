private readonly pageCache = new Map<string, ProfileAttributesDto>();

protected serverSideDatasource: IServerSideDatasource = {
  getRows: (params: IServerSideGetRowsParams) => {
    const groupKeys = params.request.groupKeys ?? [];

    if (groupKeys.length === 0) {
      const pageSize = 20;
      const startRow = params.request.startRow ?? 0;
      const page = Math.floor(startRow / pageSize);

      this.attributeService
        .loadProfilesAttributesPage({
          page,
          size: pageSize,
          entityType: 'USER',
        })
        .subscribe({
          next: response => {
            this.pageCache.clear();

            const rowData: UsersAttributesTreeRow[] = response.data.map(profile => {
              this.pageCache.set(profile.user.soeId, profile);

              return {
                id: `user-${profile.user.soeId}`,
                groupKey: profile.user.soeId,
                type: 'Użytkownik',
              };
            });

            params.success({
              rowData,
              rowCount: response.page.totalItems,
            });
          },
          error: () => params.fail(),
        });

      return;
    }

    const userSoeId = groupKeys[0];
    const profile = this.pageCache.get(userSoeId);

    const rowData: UsersAttributesTreeRow[] =
      profile?.attributes.map(attribute => ({
        id: `user-${userSoeId}-attribute-${attribute.attributeName}`,
        type: 'Atrybut',
        attributeName: attribute.attributeName,
        validFrom: attribute.validFrom,
        value: attribute.value,
      })) ?? [];

    params.success({
      rowData,
      rowCount: rowData.length,
    });
  },
};
