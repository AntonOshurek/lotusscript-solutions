import { inject, Injectable } from '@angular/core';
import type { Observable } from 'rxjs';

// ERROR
import { mapErrorToUiError } from '@shared/error';

// FIELD
import type { Field } from '../field/field';

import {
  createChangeConfirmHtml,
  getChangedFields,
  type ChangedFieldPayload,
} from '../field/field.gcm.utils';

// MODAL
import {
  MtModalService,
} from '@citi-icg-172888/ng-icgds/modal';

interface EditableRowChangePayload<
  T extends Record<string, unknown>,
> {
  original: T;
  updated: T;
  onSuccess?: () => void;
  onError?: () => void;
  onCancel?: () => void;
}

interface EditableRowChangeConfig<
  T extends Record<string, unknown>,
  TResponse,
> {
  fieldsConfig: Partial<Record<keyof T, Field>>;

  getRecordId: (row: T) => string;

  confirmTitle: string;
  confirmMessage: string;
  recordLabel: string;

  successTitle: string;
  successHtml: string;

  errorTitle: string;
  errorMessage: string;

  submit: (
    updated: T,
    changedFields: ChangedFieldPayload<T>[],
  ) => Observable<TResponse>;
}

@Injectable({
  providedIn: 'root',
})
export class EditableRowChangeService {
  private readonly modalService =
    inject(MtModalService);

  public handle<
    T extends Record<string, unknown>,
    TResponse,
  >(
    payload: EditableRowChangePayload<T>,
    config: EditableRowChangeConfig<T, TResponse>,
  ): void {
    const changedFields = getChangedFields(
      payload.original,
      payload.updated,
      config.fieldsConfig,
    );

    if (changedFields.length === 0) {
      return;
    }

    this.modalService.open({
      status: 'warning',
      title: config.confirmTitle,
      html: createChangeConfirmHtml({
        message: config.confirmMessage,
        recordLabel: config.recordLabel,
        recordId: config.getRecordId(payload.updated),
        fields: changedFields.map(field => ({
          label:
            config.fieldsConfig[field.name]?.label ??
            String(field.name),
          oldValue: field.oldValue,
          newValue: field.newValue,
          isClear: field.isClear,
        })),
      }),
      type: 'confirm',
      afterUserAction: event => {
        if (event.action === 'accept') {
          this.submit(
            payload,
            config,
            changedFields,
          );

          return;
        }

        payload.onCancel?.();
      },
    });
  }

  private submit<
    T extends Record<string, unknown>,
    TResponse,
  >(
    payload: EditableRowChangePayload<T>,
    config: EditableRowChangeConfig<T, TResponse>,
    changedFields: ChangedFieldPayload<T>[],
  ): void {
    config
      .submit(payload.updated, changedFields)
      .subscribe({
        next: () => {
          this.modalService.open({
            status: 'success',
            title: config.successTitle,
            html: config.successHtml,
            type: 'alert',
          });

          payload.onSuccess?.();
        },

        error: (error: unknown) => {
          const uiError = mapErrorToUiError(
            error,
            config.errorMessage,
          );

          this.modalService.open({
            status: 'danger',
            title: config.errorTitle,
            html: `
              <p>${uiError.title}</p>
              <p>${uiError.message}</p>
            `,
            type: 'alert',
          });

          payload.onError?.();
        },
      });
  }
}

export type {
  EditableRowChangeConfig,
  EditableRowChangePayload,
};







