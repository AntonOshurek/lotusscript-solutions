import { HttpInterceptorFn } from '@angular/common/http';
import { inject } from '@angular/core';
import { catchError, from, switchMap, throwError } from 'rxjs';

import { TokenStorageService } from '@shared/lib/auth/token-storage.service';
import { AuthService } from '@features/auth/model/auth.service';

export const authDevInterceptor: HttpInterceptorFn = (req, next) => {
  const tokenStorage = inject(TokenStorageService);
  const authService = inject(AuthService);

  const isTokenRequest = req.url.includes('/api/v1/auth/token');
  const token = tokenStorage.getToken();

  const authReq =
    token && !isTokenRequest
      ? req.clone({
          setHeaders: {
            Authorization: `Bearer ${token}`,
          },
        })
      : req;

  return next(authReq).pipe(
    catchError((err) => {
      if ((err.status === 401 || err.status === 403) && !isTokenRequest) {
        tokenStorage.clearToken();

        return from(authService.refreshDevToken()).pipe(
          switchMap((newToken) => {
            const retryReq = req.clone({
              setHeaders: {
                Authorization: `Bearer ${newToken}`,
              },
            });

            return next(retryReq);
          }),
          catchError(() => throwError(() => err))
        );
      }

      return throwError(() => err);
    })
  );
};
