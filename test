import type { GcmFieldKind, GcmFieldOperation } from '@shared/gsm';

interface Field {
  label: string;
  gcmFieldKind: GcmFieldKind;
  editable: boolean;
}

interface ChangedFieldPayload<T> {
  name: keyof T;
  op: GcmFieldOperation;
  kind: GcmFieldKind;
  value: unknown;
}

const getChangedFields = <T extends Record<string, unknown>>(
  original: T,
  updated: T,
  fields: Partial<Record<keyof T, Field>>,
): ChangedFieldPayload<T>[] => {
  return (Object.keys(fields) as Array<keyof T>)
    .filter((field) => fields[field]?.editable)
    .filter((field) => original[field] !== updated[field])
    .map((field) => {
      const value = updated[field];

      return {
        name: field,
        op: isEmptyValue(value) ? 'CLEAR' : 'SET',
        kind: fields[field]!.gcmFieldKind,
        value,
      };
    });
};

const isEmptyValue = (value: unknown): boolean => {
  return value === null || value === undefined || value === '';
};

export type { Field, ChangedFieldPayload };
export { getChangedFields };
