// row-edit.models.ts

import { z } from 'zod';

type RowEditTarget =
  | 'AMLDB_PC'
  | 'AMLDB_ACC'
  | 'AMLDB_CUST_GOLDEN'
  | 'AMLDB_PS_GOLDEN';

type RowEditValue = string | number | null;

type RowEditValues = Record<string, RowEditValue>;

interface RowEdit {
  pkValue: string;
  expectedVersion?: number;
  newValues: RowEditValues;
}

interface CreateRowEditRequest {
  targetCode: RowEditTarget;
  clientKey: string;
  onBehalfOf?: string;
  rows: RowEdit[];
}

/*
 * Zod используется только для ответа сервера.
 */
const createRowEditResponseSchema = z.object({
  data: z.object({
    requestId: z.string(),
    workflowInstanceId: z.array(z.string()).optional(),
  }),
});

type CreateRowEditResponse = z.infer<
  typeof createRowEditResponseSchema
>;

export type {
  RowEditTarget,
  RowEditValue,
  RowEditValues,
  RowEdit,
  CreateRowEditRequest,
  CreateRowEditResponse,
};

export {
  createRowEditResponseSchema,
};
