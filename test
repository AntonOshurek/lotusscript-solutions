import {
  HttpErrorResponse,
  HttpInterceptorFn,
  HttpRequest,
} from '@angular/common/http';
import { inject } from '@angular/core';
import { catchError, from, switchMap, throwError } from 'rxjs';

import { DevTokenStorageService } from '../model/dev-token-storage.service';
import { AuthService } from '../services/auth.service';

let refreshPromise: Promise<void> | null = null;

export const authDevInterceptor: HttpInterceptorFn = (req, next) => {
  const authService = inject(AuthService);
  const tokenStorage = inject(DevTokenStorageService);

  const isTokenRequest = req.url.includes('/auth/token');
  const token = tokenStorage.getToken();

  const authReq: HttpRequest<unknown> =
    token && !isTokenRequest
      ? req.clone({
          setHeaders: {
            Authorization: `Bearer ${token}`,
          },
        })
      : req;

  return next(authReq).pipe(
    catchError((err: unknown) => {
      if (!(err instanceof HttpErrorResponse)) {
        return throwError(() => err);
      }

      if (err.status !== 401 || isTokenRequest) {
        return throwError(() => err);
      }

      tokenStorage.clearToken();

      if (!refreshPromise) {
        refreshPromise = authService.login().finally(() => {
          refreshPromise = null;
        });
      }

      return from(refreshPromise).pipe(
        switchMap(() => {
          const newToken = tokenStorage.getToken();

          if (!newToken) {
            return throwError(() => err);
          }

          const retryReq = req.clone({
            setHeaders: {
              Authorization: `Bearer ${newToken}`,
            },
          });

          return next(retryReq);
        }),
      );
    }),
  );
};
